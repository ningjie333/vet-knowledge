# 构建产物
dist/
src-tauri/target/

# 依赖
node_modules/

# 环境变量（含密钥）
.env
.env.local

# 数据库文件（运行时生成）
*.db
*.db-wal
*.db-shm

# 系统文件
.DS_Store
Thumbs.db

# 临时文件
.tmp/
*.tmp

# IDE
.vscode/
.idea/

# 缓存
.ruff_cache/
.npm-cache/
__pycache__/
*.pyc

# Windows drive-letter paths (junction 破坏 / 全角冒号伪装路径)
D:/      # Unix-style D: 路径（Git Bash mingw 转换产物）
D:\\     # Windows-style D:\ 路径
# D:\dev-cache\npm 等 junction 污染衍生物（npm cache bug 6/13）
# 排除这些防止 git add 误入
