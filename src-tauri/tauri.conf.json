{
  "$schema": "https://schemas.tauri.app/config/2",
  "productName": "兽医知识库",
  "version": "0.1.0",
  "identifier": "com.vetknowledge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "兽医知识库",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon_32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_256x256.png",
      "icons/icon_512x512.png",
      "icons/icon.ico"
    ],
    "publisher": "vet-knowledge",
    "copyright": "© 2026 vet-knowledge"
  }
}
